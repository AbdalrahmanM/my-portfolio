# Required for email delivery.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@mudher.com
CONTACT_TO_EMAIL=abdodj18@gmail.com

# Comma-separated public origins, for example https://portfolio.example.com.
CONTACT_ALLOWED_ORIGINS=

# Use a long random value to hash temporary rate-limit identifiers.
CONTACT_RATE_LIMIT_SALT=

# Optional but recommended bot protection from Cloudflare Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAME=
